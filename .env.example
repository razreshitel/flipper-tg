# Copy this to .env and fill in your values
BOT_TOKEN=1234567890:YOUR_BOT_TOKEN_HERE

# Optional: SOCKS5 proxy for Telegram API (leave empty if not needed)
SOCKS_PROXY=

# Server bind address and port
HOST=0.0.0.0
PORT=8888

# Secret token — must match what you set on the Flipper (creds.txt)
FLIPPER_SECRET=change-me
